          "to": "ɽ",
          "note": "Standard retroflex flap ड़ in words like करड़ा (karɽā 'bitter')"
        },
        {
          "from": "vara",
          "to": "vaɽā",
          "note": "Assimilation context: preceding retroflex consonants trigger flapping"
        }
